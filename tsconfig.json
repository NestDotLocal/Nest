{
    "compilerOptions": {
        // Environment setup & latest features
        "lib": ["ESNext", "DOM"],
        "target": "ESNext",
        "module": "Preserve",
        "moduleDetection": "force",
        "jsx": "react-jsx",
        "allowJs": true,

        // Bundler mode
        "moduleResolution": "bundler",
        "allowImportingTsExtensions": true,
        "verbatimModuleSyntax": true,
        "noEmit": true,

        // Best practices
        "strict": true,
        "skipLibCheck": true,
        "noFallthroughCasesInSwitch": true,
        "noUncheckedIndexedAccess": true,
        "noImplicitOverride": true,

        // Path aliases
        "paths": {
            "@nest/storage": ["./src/lib/storage.ts"],
            "@nest/room": ["./src/lib/room.ts"],
            "@nest/router": ["./src/lib/router.ts"],
            "@nest/cache": ["./src/shared/cache.ts"],
            "@nest/toast": ["./src/shared/toast.ts"],
            "@nest/keys": ["./src/shared/keys.ts"],
            "@nest/sidebar": ["./src/shared/sidebar.ts"],
            "@nest/rooms/*": ["./src/rooms/*"]
        },

        // Some stricter flags (disabled by default)
        "noUnusedLocals": false,
        "noUnusedParameters": false,
        "noPropertyAccessFromIndexSignature": false
    }
}
